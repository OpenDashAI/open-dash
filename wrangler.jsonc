{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "open-dash",
  "compatibility_date": "2026-03-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/worker.ts",
  "durable_objects": {
    "bindings": [
      {
        "name": "HUD_SOCKET",
        "class_name": "HudSocket",
        "script_name": "open-dash"
      },
      {
        "name": "COMPETITIVE_INTEL",
        "class_name": "CompetitiveIntelligenceCoordinator",
        "script_name": "open-dash"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["HudSocket"]
    },
    {
      "tag": "v2",
      "new_classes": ["CompetitiveIntelligenceCoordinator"]
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "open-dash-db",
      "database_id": "ecb3df92-04a4-45ef-8c6e-d4a8e84b4d7f"
    }
  ]
  // Secrets (set via `wrangler secret put`):
  // - API_MOM_URL: API Mom proxy URL (https://apimom.dev)
  // - API_MOM_KEY: API Mom project key for open-dash
  // - OPENROUTER_KEY: OpenRouter API key (BYOK through API Mom)
  // - TAILSCALE_API_KEY: Tailscale API key for machine status
  // - GITHUB_TOKEN: GitHub PAT for issues/activity data
  // - SM_API_URL: Scalable Media API URL (L2 orchestrator)
  // - SM_SERVICE_KEY: Scalable Media X-Service-Key (L2 orchestrator)
  // - RESEND_API_KEY: Resend email service API key (for team invites)
  // - CLERK_SECRET_KEY: Clerk secret key (for JWT validation)
  // - CLERK_PUBLISHABLE_KEY: Clerk publishable key (for frontend)
  //
  // Scram Jet Integration (EPIC #99):
  // - SCRAMJET_WEBHOOK_SECRET: Bearer token for Scram Jet → /api/metrics webhook validation
  //
  // Competitive Intelligence Secrets (Week 1+):
  // - BRAVE_API_KEY: BraveSearch API key for SERP tracking
  // - SIMILARWEB_API_KEY: SimilarWeb API key for domain metrics (optional)
  // - SEMRUSH_API_KEY: Semrush API key for SEO data (optional)
  // - TWITTER_API_KEY: Twitter/X API key for social monitoring (optional)
}
