# Environment Variables for OpenDash Development
# Copy this to .env.local and fill in with real values (secrets should be in .env.local.gitignore)
# NEVER commit actual secrets to git

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_PLACEHOLDER_DO_NOT_USE_REAL_KEY
CLERK_PUBLISHABLE_KEY=pk_test_PLACEHOLDER_DO_NOT_USE_REAL_KEY

# Resend Email Service
RESEND_API_KEY=re_PLACEHOLDER_DO_NOT_USE_REAL_KEY

# Service-to-Service Authentication (for webhook validation)
SM_SERVICE_KEY=svc_PLACEHOLDER_DO_NOT_USE_REAL_KEY

# Allowed IPs (comma-separated, for bypassing auth in development)
ALLOWED_IPS=127.0.0.1,::1

# Database URL (D1 is auto-managed by Cloudflare Workers, no manual config needed)
# D1_DATABASE_ID=your-d1-database-id
