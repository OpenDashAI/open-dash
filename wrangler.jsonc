{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "open-dash",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry"
  // Secrets (set via `wrangler secret put`):
  // - API_MOM_URL: API Mom proxy URL (https://apimom.dev)
  // - API_MOM_KEY: API Mom project key for open-dash
  // - OPENROUTER_KEY: OpenRouter API key (BYOK through API Mom)
  // - TAILSCALE_API_KEY: Tailscale API key for machine status
  // - GITHUB_TOKEN: GitHub PAT for issues/activity data
}
